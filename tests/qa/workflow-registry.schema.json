{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["qualityBar", "lastReviewed", "workflows"],
  "properties": {
    "qualityBar": {
      "const": "public_launch"
    },
    "lastReviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "journey",
          "personas",
          "positiveCases",
          "negativeCases",
          "automationLayers",
          "owner",
          "releaseGate",
          "regressionRisks"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "journey": {
            "type": "string",
            "minLength": 1
          },
          "personas": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "positiveCases": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "negativeCases": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "automationLayers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": ["unit", "api", "database_rls", "e2e", "persona_review"]
            }
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "releaseGate": {
            "enum": ["every_pr", "nightly", "pre_release"]
          },
          "regressionRisks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
